{
  "sources": [
    {
      "path": "examples/example_triplet_pH_6_5.xlsx",
      "format": "triplet_excel",
      "ph": 6.5
    },
    {
      "path": "examples/example_triplet_pH_7_4.xlsx",
      "format": "triplet_excel",
      "ph": 7.4
    }
  ],
  "family_rules": [
    {"contains": "NanoA", "family": "NanoA"},
    {"contains": "NanoB", "family": "NanoB"}
  ],
  "default_family": "Other",
  "plot": {
    "output_dir": "heatmap_outputs",
    "value_label": "$\\ln(\\mathrm{DEF}_{\\mathrm{ROS}})$",
    "colorbar_note": "blue: ROS decrease vs control; red: ROS increase vs control",
    "dose_label": "Dose, Gy",
    "concentration_label": "Conc, mg/mL",
    "panel_label": "pH",
    "cmap": "bwr",
    "center": 0,
    "global_color_scale": true,
    "annotate": true,
    "group_titles": {
      "NanoA": "NanoA",
      "NanoB": "NanoB"
    },
    "material_order": {
      "NanoA": ["NanoA 5%"],
      "NanoB": ["NanoB"]
    },
    "output_names": {
      "NanoA": "excel_heatmap_NanoA.png",
      "NanoB": "excel_heatmap_NanoB.png"
    }
  }
}
